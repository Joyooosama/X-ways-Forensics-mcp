{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.xwf-mcp/schemas/volume-snapshot.schema.json",
  "title": "XWF Volume Snapshot Summary",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "evidence_object": {
      "type": ["string", "null"]
    },
    "total_items": {
      "type": ["integer", "string", "null"]
    },
    "previous_items": {
      "type": ["integer", "string", "null"]
    },
    "delta_items": {
      "type": ["integer", "string", "null"]
    },
    "duration_minutes_text": {
      "type": ["string", "null"]
    },
    "message": {
      "type": ["string", "null"]
    },
    "_source_file": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
